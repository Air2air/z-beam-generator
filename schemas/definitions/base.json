{
  "baseProfile": {
    "name": "base",
    "version": "1.4",
    "schemaType": "BaseProfile",
    "generatorConfig": {
      "tags": {
        "primaryKeywords": ["laser cleaning", "{subject} laser cleaning"],
        "maxTags": 8,
        "maxKeywords": 12
      },
      "jsonld": {
        "additionalProperties": [
          {
            "name": "applicationCategory",
            "value": "Laser Cleaning Technology"
          }
        ],
        "requiredProperties": ["@context", "@type", "headline", "description", "author", "url", "keywords", "about"],
        "recommendedProperties": ["datePublished", "dateModified", "publisher", "hasPart", "mentions"]
      },
      "frontmatter": {
        "includeDescription": true,
        "includeAuthor": true,
        "includeKeywords": true,
        "includeTags": true,
        "includePublicationDate": true,
        "maxLength": 3000,
        "minLength": 2000
      }
    },
    "sections": {
      "environmentalImpact": {
        "required": true,
        "prompt": "Summarize environmental impact of {subject} in laser cleaning, focusing on waste reduction and energy efficiency (100–150 words)."
      },
      "businessImplications": {
        "required": false,
        "prompt": "Outline business implications of {subject} in laser cleaning, including cost benefits and market trends (100–150 words)."
      }
    },
    "profile": {
      "name": {
        "type": "string",
        "required": true,
        "description": "Article title (e.g., 'Fluence')",
        "example": "{subject}"
      },
      "description": {
        "type": "string",
        "required": true,
        "description": "Technical summary of {subject} in laser cleaning (150–200 words)",
        "example": "Fluence (J/cm²) is critical for precision laser cleaning..."
      },
      "website": {
        "type": "string",
        "required": true,
        "description": "Canonical Tito  URL[](https://www.z-beam.com/[subject]-laser-cleaning)",
        "example": "https://www.z-beam.com/fluence-laser-cleaning"
      },
      "author": {
        "type": "object",
        "required": true,
        "properties": {
          "name": {
            "type": "string",
            "required": true,
            "description": "Author or organization name",
            "example": "Laser Technology Institute"
          },
          "credentials": {
            "type": "string",
            "required": true,
            "description": "Author credentials for E-A-T",
            "example": "Industry Leader in Laser Cleaning Technology"
          }
        }
      },
      "keywords": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "required": true,
        "description": "10–12 technical keywords for SEO and search",
        "example": ["laser fluence calibration", "pulsed laser ablation", "industrial laser parameters"]
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "required": true,
        "description": "5–8 hyphenated tags for on-site navigation",
        "example": ["fluence-calibration", "laser-cleaning", "surface-treatment"]
      },
      "applications": {
        "type": "array",
        "required": false,
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "required": true,
              "description": "Application name",
              "example": "Aerospace Coating Removal"
            },
            "description": {
              "type": "string",
              "required": true,
              "description": "Use case description (50–75 words)",
              "example": "Fluence of 2–10 J/cm² removes epoxy coatings..."
            }
          }
        },
        "description": "3–4 use cases for application/thesaurus articles"
      },
      "technicalSpecifications": {
        "type": "object",
        "required": false,
        "properties": {
          "laserType": {
            "type": "string",
            "description": "Type of laser used",
            "example": "Hafnium-doped fiber"
          },
          "wavelength": {
            "type": "string",
            "description": "Laser wavelength",
            "example": "1064nm ±2nm"
          },
          "powerRange": {
            "type": "string",
            "description": "Power range",
            "example": "50–1000W pulsed"
          },
          "fluenceRange": {
            "type": "string",
            "description": "Fluence range",
            "example": "0.1–15 J/cm²"
          },
          "pulseDuration": {
            "type": "string",
            "description": "Pulse duration",
            "example": "10–200ns"
          }
        },
        "description": "Technical parameters for material/thesaurus articles"
      },
      "facilities": {
        "type": "array",
        "required": false,
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "required": true,
              "description": "Facility name",
              "example": "Z-Beam Tech Center"
            },
            "location": {
              "type": "string",
              "required": true,
              "description": "California city, county, and state",
              "example": "San Diego, San Diego County, California"
            },
            "coordinates": {
              "type": "string",
              "required": true,
              "description": "Geographic coordinates",
              "example": "32.7157° N, 117.1611° W"
            },
            "description": {
              "type": "string",
              "required": true,
              "description": "Facility description (50–75 words)",
              "example": "R&D hub for naval corrosion removal..."
            }
          }
        },
        "description": "1–3 California facilities for region articles"
      },
      "regulatoryStandards": {
        "type": "array",
        "required": true,
        "items": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "required": true,
              "description": "Standard code",
              "example": "ANSI Z136.1"
            },
            "description": {
              "type": "string",
              "required": true,
              "description": "Compliance description (50–75 words)",
              "example": "Class IV laser safety, requiring interlocks..."
            }
          }
        },
        "description": "2–3 compliance standards"
      },
      "challenges": {
        "type": "array",
        "required": false,
        "items": {
          "type": "object",
          "properties": {
            "issue": {
              "type": "string",
              "required": true,
              "description": "Technical challenge",
              "example": "Thermal Damage to Composites"
            },
            "solution": {
              "type": "string",
              "required": true,
              "description": "Solution description (50–75 words)",
              "example": "Pulse shaping adjusts fluence..."
            }
          }
        },
        "description": "1–3 challenges and solutions"
      },
      "outcomes": {
        "type": "array",
        "required": true,
        "items": {
          "type": "object",
          "properties": {
            "result": {
              "type": "string",
              "required": true,
              "description": "Measurable result",
              "example": "99.7% paint removal"
            },
            "metric": {
              "type": "string",
              "required": true,
              "description": "Measurement standard",
              "example": "ASTM D3359 adhesion test"
            }
          }
        },
        "description": "2–3 measurable outcomes"
      },
      "environmentalImpact": {
        "type": "object",
        "required": true,
        "properties": {
          "description": {
            "type": "string",
            "required": true,
            "description": "Environmental impact summary (100–150 words)",
            "example": "Laser cleaning reduces chemical waste by 90%..."
          },
          "metrics": {
            "type": "array",
            "required": false,
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "required": true,
                  "example": "Waste Reduction"
                },
                "value": {
                  "type": "string",
                  "required": true,
                  "example": "90%"
                },
                "unit": {
                  "type": "string",
                  "required": false,
                  "example": "%"
                }
              }
            }
          }
        }
      },
      "contentManagement": {
        "type": "object",
        "required": false,
        "properties": {
          "articleType": {
            "type": "string",
            "required": true,
            "description": "Article type (application, material, region, thesaurus)",
            "example": "thesaurus"
          },
          "publishedAt": {
            "type": "string",
            "format": "date",
            "required": false,
            "description": "Publication date",
            "example": "2025-07-17"
          },
          "lastUpdated": {
            "type": "string",
            "format": "date",
            "required": false,
            "description": "Last update date",
            "example": "2025-07-17"
          }
        }
      },
      "relatedContent": {
        "type": "array",
        "required": false,
        "items": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "required": true,
              "example": "Laser Ablation Techniques"
            },
            "url": {
              "type": "string",
              "required": true,
              "example": "https://www.z-beam.com/laser-ablation-laser-cleaning"
            },
            "type": {
              "type": "string",
              "required": true,
              "example": "thesaurus"
            }
          }
        },
        "description": "Related articles for navigation"
      }
    },
    "jsonLD": {
      "requiredProperties": [
        "@context",
        "@type",
        "headline",
        "description",
        "author",
        "url",
        "keywords",
        "about"
      ],
      "recommendedProperties": [
        "datePublished",
        "dateModified",
        "publisher",
        "hasPart",
        "mentions",
        "relatedLink"
      ],
      "mappings": {
        "name": "headline",
        "description": "description",
        "website": "url",
        "author.name": "author.name",
        "author.credentials": "author.description",
        "keywords": "keywords",
        "tags": "about.category",
        "applications": "hasPart",
        "technicalSpecifications": "about.additionalProperty",
        "facilities": "publisher.location",
        "regulatoryStandards": "about.legislationApplied",
        "challenges": "mentions",
        "outcomes": "about.potentialAction",
        "environmentalImpact.description": "about.environmentalImpact",
        "environmentalImpact.metrics": "about.potentialAction",
        "contentManagement.publishedAt": "datePublished",
        "contentManagement.lastUpdated": "dateModified",
        "relatedContent": "relatedLink"
      }
    },
    "validation": {
      "jsonLD": {
        "requiredProperties": [
          "@context",
          "@type",
          "headline",
          "description",
          "author",
          "url",
          "keywords",
          "about"
        ],
        "recommendedProperties": [
          "datePublished",
          "dateModified",
          "publisher",
          "hasPart",
          "mentions",
          "relatedLink"
        ],
        "minLength": 1000,
        "maxLength": 2000,
        "schemaOrgType": "TechnicalArticle",
        "schemaOrgCompliance": true,
        "validPropertiesOnly": true
      },
      "frontmatter": {
        "requiredFields": ["name", "description", "website", "author", "keywords", "tags", "environmentalImpact", "regulatoryStandards", "outcomes"],
        "minLength": 2000,
        "maxLength": 3000
      }
    }
  }
}