{
  "baseProfile": {
    "name": "base",
    "version": "1.3",
    "schemaType": "BaseProfile",
    "generatorConfig": {
      "tags": {
        "primaryKeywords": ["laser cleaning", "{subject}"]
      },
      "jsonld": {
        "additionalProperties": [
          {
            "name": "applicationCategory",
            "value": "Laser cleaning"
          }
        ]
      },
      "frontmatter": {
        "includeDescription": true,
        "includeAuthor": true,
        "includeKeywords": true,
        "includePublicationDate": true
      }
    },
    "sections": {
      "environmentalImpact": {
        "required": true,
        "prompt": "Summarize environmental impact of {subject} in laser cleaning, including waste reduction and energy efficiency. Provide key metrics and examples (100-150 words)."
      },
      "businessImplications": {
        "required": false,
        "prompt": "Outline business implications of {subject} in laser cleaning, including cost-benefit and market trends (100-150 words)."
      }
    },
    "profile": {
      "name": {
        "type": "string",
        "required": true,
        "description": "Name of the subject"
      },
      "description": {
        "type": "string",
        "required": true,
        "description": "Overview of the subject in laser cleaning context"
      },
      "keywords": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "required": true,
        "description": "Keywords for SEO and JSON-LD"
      },
      "environmentalImpact": {
        "type": "object",
        "required": true,
        "properties": {
          "description": {
            "type": "string",
            "required": true
          },
          "metrics": {
            "type": "array",
            "required": false,
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "required": true
                },
                "value": {
                  "type": "string",
                  "required": true
                },
                "unit": {
                  "type": "string",
                  "required": false
                }
              }
            }
          }
        }
      },
      "safetyConsiderations": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "required": true,
        "description": "Safety requirements"
      },
      "regulatoryStandards": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "required": true,
        "description": "Relevant standards (e.g., OSHA, ISO)"
      },
      "researchData": {
        "type": "object",
        "required": false,
        "properties": {
          "studies": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string",
                  "required": true
                },
                "authors": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "required": false
                },
                "publication": {
                  "type": "string",
                  "required": false
                },
                "year": {
                  "type": "string",
                  "required": false
                },
                "url": {
                  "type": "string",
                  "required": false
                }
              }
            }
          }
        }
      },
      "author": {
        "id": {
          "type": "string",
          "required": true
        },
        "name": {
          "type": "string",
          "required": true
        },
        "title": {
          "type": "string",
          "required": false
        },
        "country": {
          "type": "string",
          "required": false
        },
        "image": {
          "type": "string",
          "required": false
        },
        "slug": {
          "type": "string",
          "required": false
        },
        "url": {
          "type": "string",
          "required": false
        }
      },
      "contentManagement": {
        "type": "object",
        "required": true,
        "properties": {
          "articleType": {
            "type": "string",
            "required": true
          },
          "publishedAt": {
            "type": "string",
            "format": "date",
            "required": false
          },
          "lastUpdated": {
            "type": "string",
            "format": "date",
            "required": false
          },
          "generationTimestamp": {
            "type": "string",
            "format": "date-time",
            "required": false
          },
          "modelUsed": {
            "type": "string",
            "required": false
          }
        }
      },
      "relatedContent": {
        "type": "array",
        "required": false,
        "items": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "required": true
            },
            "url": {
              "type": "string",
              "required": true
            },
            "type": {
              "type": "string",
              "required": true
            }
          }
        }
      }
    },
    "jsonLD": {
      "requiredProperties": [
        "headline",
        "description",
        "author",
        "datePublished"
      ],
      "recommendedProperties": ["dateModified", "publisher", "keywords"]
    },
    "validation": {
      "jsonLD": {
        "requiredProperties": [
          "headline",
          "description",
          "author",
          "datePublished"
        ],
        "recommendedProperties": ["dateModified", "publisher", "keywords"]
      }
    }
  }
}

