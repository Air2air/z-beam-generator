{
  "regionProfile": {
    "name": "region",
    "version": "1.4",
    "schemaType": "RegionProfile",
    "generatorConfig": {
      "tags": {
        "includeCountries": true,
        "includeIndustries": true
      },
      "jsonld": {
        "schemaType": "Place",
        "includeGeo": true
      },
      "frontmatter": {
        "includeLocation": true
      },
      "contentGeneration": {
        "dynamicSectionsFromFrontmatter": true,
        "fieldContentMapping": {
          "countries": "Describe the key countries in {subject} region and their relevance to laser cleaning applications",
          "economicData": "Analyze the economic landscape of {subject} and how it impacts laser technology adoption",
          "manufacturingCenters": "Detail the major manufacturing centers in {subject} and their laser cleaning implementations",
          "laserCleaningData": "Explain current laser cleaning adoption trends in {subject} region",
          "caseStudies": "Present relevant case studies showcasing laser cleaning success in {subject}"
        },
        "introductionPrompt": "Provide a comprehensive overview of region..."
      }
    },
    "profile": {
      "countries": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "required": true
      },
      "geoCoordinates": {
        "type": "object",
        "required": true,
        "properties": {
          "latitude": {
            "type": "string",
            "required": true
          },
          "longitude": {
            "type": "string",
            "required": true
          }
        }
      },
      "economicData": {
        "type": "object",
        "required": true,
        "properties": {
          "gdp": {
            "type": "string",
            "required": false
          },
          "majorIndustries": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "required": true
          },
          "tradePartners": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "required": false
          }
        }
      },
      "manufacturingCenters": {
        "type": "array",
        "required": true,
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "required": true
            },
            "description": {
              "type": "string",
              "required": true
            },
            "laserCleaningUsage": {
              "type": "string",
              "required": false
            }
          }
        }
      }
    },
    "facilities": {
      "type": "array",
      "required": false,
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "required": true,
            "description": "Facility name",
            "example": "Z-Beam Tech Center"
          },
          "location": {
            "type": "string",
            "required": true,
            "description": "California city, county, and state",
            "example": "San Diego, San Diego County, California"
          },
          "coordinates": {
            "type": "string",
            "required": true,
            "description": "Geographic coordinates",
            "example": "32.7157° N, 117.1611° W"
          },
          "description": {
            "type": "string",
            "required": true,
            "description": "Facility description (50–75 words)",
            "example": "R&D hub for naval corrosion removal..."
          }
        }
      },
      "description": "1–3 California facilities for region articles"
    },
    "validation": {
      "frontmatter": {
        "requiredFields": [
          "name",
          "description",
          "website",
          "author",
          "keywords",
          "tags",
          "countries",
          "geoCoordinates",
          "economicData"
        ]
      }
    }
  }
}
