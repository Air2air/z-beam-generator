{
  "name": "material",
  "version": "1.1",
  "schemaType": "MaterialProfile",
  "generatorConfig": {
    "tags": {
      "includeMaterialCategories": true,
      "includeApplications": true,
      "includeIndustries": true,
      "primaryKeywords": [
        "laser cleaning",
        "{subject}",
        "material properties",
        "industrial materials",
        "surface cleaning",
        "manufacturing"
      ]
    },
    "jsonld": {
      "schemaType": "TechArticle",
      "includeProperties": true,
      "includeSpecifications": true,
      "includeApplications": true,
      "additionalProperties": [
        {
          "name": "materialCategory",
          "value": "Category of the material (e.g., metal, ceramic)"
        },
        {
          "name": "laserCleaningContext",
          "value": "Applications and outcomes of laser cleaning for {subject}"
        }
      ]
    },
    "metadata": {
      "includeDescription": true,
      "includeAuthor": true,
      "includeKeywords": true,
      "includePublicationDate": true,
      "category": "MaterialProperties"
    }
  },
  "sections": {
    "overview": {
      "required": true,
      "prompt": "Write an engaging overview of {subject}, highlighting its importance in various industries and how laser cleaning enhances its maintenance, preservation, or restoration. Include its definition, basic properties, primary uses, and relevance to laser cleaning applications. Keep it concise but informative (150-200 words), emphasizing technical, scientific, and business value."
    },
    "properties": {
      "required": true,
      "prompt": "Describe the key properties of {subject} in paragraph form, including physical (e.g., density, melting point), chemical (e.g., composition, reactivity), mechanical (e.g., tensile strength, hardness), thermal (e.g., conductivity, specific heat), and optical properties (e.g., reflectivity, absorption at laser wavelengths). Provide specific measurements with units, reference standards (e.g., ASTM, ISO), and discuss how these properties impact laser cleaning. Write 250-300 words."
    },
    "applications": {
      "required": true,
      "prompt": "Explain the main applications of {subject} in paragraph form, covering industries (e.g., aerospace, construction), specific products or components, and reasons for its selection. Include how laser cleaning is applied to these uses, with examples of outcomes (e.g., corrosion removal, surface preparation). Write 200-250 words."
    },
    "specifications": {
      "required": true,
      "prompt": "Describe the standard specifications, grades, and quality metrics for {subject} in paragraph form. Include industry standards (e.g., ASTM, ISO), common alloys or formulations, testing methods, and quality control considerations relevant to laser cleaning. Write 150-200 words."
    },
    "laserCleaningApplications": {
      "required": false,
      "prompt": "Detail specific laser cleaning applications for {subject}, including suitable laser types (e.g., fiber, pulsed), parameters (e.g., fluence, wavelength), and outcomes (e.g., removal efficiency, surface integrity). Provide case studies or examples, quantitative results, and industry-specific benefits where possible. Write 200-250 words."
    },
    "challenges": {
      "required": false,
      "prompt": "Discuss challenges in using laser cleaning on {subject}, such as material sensitivity, parameter optimization, or cost considerations. Provide potential solutions, mitigation strategies, and examples of successful implementations. Write 150-200 words."
    },
    "performanceMetrics": {
      "required": false,
      "prompt": "Detail performance metrics for laser cleaning of {subject}, including cycle time, surface roughness, energy consumption, cleaning efficiency, and removal rate. Use specific values with units, cite data sources (e.g., industry reports, ASTM standards), and compare to traditional methods where possible. Write 150-200 words."
    },
    "businessImplications": {
      "required": false,
      "prompt": "Analyze the business implications of using laser cleaning on {subject}, including cost-benefit analysis, scalability, market adoption trends, and competitive advantages. Discuss how it influences decision-making in industries using this material. Write 150-200 words."
    }
  },
