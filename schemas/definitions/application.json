{
  "applicationProfile": {
    "name": "application",
    "version": "1.3",
    "schemaType": "LaserCleaningApplicationProfile",
    "generatorConfig": {
      "tags": {
        "includeTags": true,
        "maxTags": 8,
        "maxKeywords": 12,
        "primaryKeywords": ["laser cleaning", "{subject} laser cleaning"]
      },
      "jsonld": {
        "schemaType": "TechnicalArticle",
        "additionalProperties": [
          {
            "name": "applicationCategory",
            "value": "Laser Cleaning Technology"
          }
        ],
        "requiredProperties": ["@context", "@type", "headline", "description", "author", "url", "keywords", "about"],
        "recommendedProperties": ["hasPart", "publisher", "mentions", "datePublished", "dateModified"]
      },
      "frontmatter": {
        "category": "LaserApplications",
        "minLength": 2000,
        "maxLength": 3000
      }
    },
    "sections": {
      "overview": {
        "required": true,
        "prompt": "Write a 150–200 word technical overview of {subject} laser cleaning application, focusing on definition, benefits, and key industries."
      },
      "applications": {
        "required": true,
        "prompt": "Provide 3–4 use cases for {subject}, with name and 50–75 word description, emphasizing technical outcomes."
      },
      "technicalSpecifications": {
        "required": true,
        "prompt": "Summarize key laser parameters for {subject}, including wavelength, power, and fluence, with essential ranges and units."
      },
      "outcomes": {
        "required": true,
        "prompt": "Provide 2–3 measurable outcomes for {subject}, with result and metric (e.g., ASTM standards)."
      },
      "challenges": {
        "required": true,
        "prompt": "Outline 1–3 technical challenges for {subject}, with 50–75 word solutions."
      },
      "environmentalImpact": {
        "required": true,
        "prompt": "Summarize environmental impact of {subject}, focusing on waste reduction and energy efficiency (100–150 words)."
      }
    },
    "profile": {
      "name": {
        "type": "string",
        "required": true,
        "description": "Application name (e.g., 'Aerospace Coating Removal')",
        "example": "{subject}"
      },
      "description": {
        "type": "string",
        "required": true,
        "description": "Technical overview (150–200 words)",
        "example": "Aerospace coating removal uses laser cleaning to strip epoxy..."
      },
      "website": {
        "type": "string",
        "required": true,
        "description": "URL (https://www.z-beam.com/[subject]-laser-cleaning)",
        "example": "https://www.z-beam.com/aerospace-coating-removal-laser-cleaning"
      },
      "author": {
        "type": "object",
        "required": true,
        "properties": {
          "name": {
            "type": "string",
            "required": true,
            "description": "Author or organization name",
            "example": "Laser Technology Institute"
          },
          "credentials": {
            "type": "string",
            "required": true,
            "description": "Credentials for E-A-T",
            "example": "Industry Leader in Laser Cleaning Technology"
          }
        }
      },
      "keywords": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "required": true,
        "description": "10–12 technical keywords for SEO and search",
        "example": ["aerospace coating removal", "laser cleaning", "surface preparation"]
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "required": true,
        "description": "5–8 hyphenated tags for on-site navigation",
        "example": ["coating-removal", "laser-cleaning", "aerospace"]
      },
      "applications": {
        "type": "array",
        "required": true,
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "required": true,
              "description": "Use case name",
              "example": "Turbine Blade Cleaning"
            },
            "description": {
              "type": "string",
              "required": true,
              "description": "Use case description (50–75 words)",
              "example": "Fluence of 2–10 J/cm² removes coatings from turbine blades..."
            }
          }
        },
        "description": "3–4 specific use cases"
      },
      "technicalSpecifications": {
        "type": "object",
        "required": true,
        "properties": {
          "laserType": {
            "type": "string",
            "description": "Type of laser",
            "example": "Hafnium-doped fiber"
          },
          "wavelength": {
            "type": "string",
            "description": "Wavelength",
            "example": "1064nm ±2nm"
          },
          "powerRange": {
            "type": "string",
            "description": "Power range",
            "example": "50–1000W pulsed"
          },
          "fluenceRange": {
            "type": "string",
            "description": "Fluence range",
            "example": "0.1–15 J/cm²"
          },
          "pulseDuration": {
            "type": "string",
            "description": "Pulse duration",
            "example": "10–200ns"
          }
        },
        "description": "Key technical parameters"
      },
      "regulatoryStandards": {
        "type": "array",
        "required": true,
        "items": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "required": true,
              "description": "Standard code",
              "example": "ANSI Z136.1"
            },
            "description": {
              "type": "string",
              "required": true,
              "description": "Compliance description (50–75 words)",
              "example": "Class IV laser safety, requiring interlocks..."
            }
          }
        },
        "description": "2–3 compliance standards"
      },
      "challenges": {
        "type": "array",
        "required": true,
        "items": {
          "type": "object",
          "properties": {
            "issue": {
              "type": "string",
              "required": true,
              "description": "Technical challenge",
              "example": "Thermal Damage"
            },
            "solution": {
              "type": "string",
              "required": true,
              "description": "Solution (50–75 words)",
              "example": "Pulse shaping adjusts fluence..."
            }
          }
        },
        "description": "1–3 challenges and solutions"
      },
      "outcomes": {
        "type": "array",
        "required": true,
        "items": {
          "type": "object",
          "properties": {
            "result": {
              "type": "string",
              "required": true,
              "description": "Measurable result",
              "example": "99.7% coating removal"
            },
            "metric": {
              "type": "string",
              "required": true,
              "description": "Measurement standard",
              "example": "ASTM D3359"
            }
          }
        },
        "description": "2–3 measurable outcomes"
      },
      "environmentalImpact": {
        "type": "object",
        "required": true,
        "properties": {
          "description": {
            "type": "string",
            "required": true,
            "description": "Environmental impact summary (100–150 words)",
            "example": "Laser cleaning reduces chemical waste by 90%..."
          },
          "metrics": {
            "type": "array",
            "required": false,
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "required": true,
                  "example": "Waste Reduction"
                },
                "value": {
                  "type": "string",
                  "required": true,
                  "example": "90%"
                },
                "unit": {
                  "type": "string",
                  "required": false,
                  "example": "%"
                }
              }
            }
          }
        }
      }
    },
    "jsonLD": {
      "@type": "TechnicalArticle",
      "requiredProperties": ["@context", "@type", "headline", "description", "author", "url", "keywords", "about"],
      "recommendedProperties": ["hasPart", "publisher", "mentions", "datePublished", "dateModified"],
      "mappings": {
        "name": "headline",
        "description": "description",
        "website": "url",
        "author.name": "author.name",
        "author.credentials": "author.description",
        "keywords": "keywords",
        "tags": "about.category",
        "applications": "hasPart",
        "technicalSpecifications": "about.additionalProperty",
        "regulatoryStandards": "about.legislationApplied",
        "challenges": "mentions",
        "outcomes": "about.potentialAction",
        "environmentalImpact.description": "about.environmentalImpact",
        "environmentalImpact.metrics": "about.potentialAction"
      }
    },
    "validation": {
      "requiredSections": ["overview", "applications", "technicalSpecifications", "outcomes", "challenges", "environmentalImpact"],
      "jsonLD": {
        "minLength": 1000,
        "maxLength": 2000,
        "schemaOrgType": "TechnicalArticle",
        "schemaOrgCompliance": true,
        "validPropertiesOnly": true
      },
      "frontmatter": {
        "requiredFields": ["name", "description", "website", "author", "keywords", "tags", "applications", "technicalSpecifications", "regulatoryStandards", "outcomes", "environmentalImpact"],
        "minLength": 2000,
        "maxLength": 3000
      }
    }
  }
}