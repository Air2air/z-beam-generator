{
  "materialProfile": {
    "name": "material",
    "version": "1.3",
    "schemaType": "MaterialProfile",
    "generatorConfig": {
      "jsonld": {
        "schemaType": "Product"
      },
      "contentGeneration": {
        "dynamicSectionsFromFrontmatter": true,
        "fieldContentMapping": {
          "properties": "Detail the physical and chemical properties of {subject} relevant to laser cleaning",
          "laserParameters": "Explain the optimal laser parameters for cleaning {subject}, including wavelength, fluence, and pulse duration",
          "applications": "Describe the key applications where {subject} is processed using laser cleaning",
          "challenges": "Analyze the specific challenges in laser cleaning {subject} and their technical solutions",
          "safetyConsiderations": "Outline the safety considerations and protocols when laser cleaning {subject}"
        },
        "introductionPrompt": "Provide a comprehensive technical overview of {subject} as a material in laser cleaning applications"
      }
    },
    "profile": {
      "properties": {
        "type": "object",
        "required": true,
        "properties": {
          "density": {
            "type": "string",
            "description": "Material density",
            "example": "2.7 g/cm³"
          },
          "meltingPoint": {
            "type": "string",
            "description": "Melting point",
            "example": "660°C"
          },
          "thermalConductivity": {
            "type": "string",
            "description": "Thermal conductivity",
            "example": "237 W/m·K"
          },
          "laserType": {
            "type": "string",
            "description": "Laser type for cleaning",
            "example": "Hafnium-doped fiber"
          },
          "wavelength": {
            "type": "string",
            "description": "Laser wavelength",
            "example": "1064nm ±2nm"
          },
          "fluenceRange": {
            "type": "string",
            "description": "Fluence range",
            "example": "0.1–15 J/cm²"
          }
        },
        "description": "Physical, chemical, and laser cleaning parameters"
      },
      "composition": {
        "type": "array",
        "required": true,
        "items": {
          "type": "object",
          "properties": {
            "element": {
              "type": "string",
              "required": true,
              "description": "Chemical element",
              "example": "Aluminum"
            },
            "percentage": {
              "type": "string",
              "required": true,
              "description": "Weight percentage in the material",
              "example": "100%"
            }
          }
        },
        "description": "Chemical composition by element"
      },
      "compatibility": {
        "type": "array",
        "required": true,
        "items": {
          "type": "object",
          "properties": {
            "material": {
              "type": "string",
              "required": true,
              "description": "Compatible material",
              "example": "Stainless Steel"
            },
            "application": {
              "type": "string",
              "required": true,
              "description": "Application or process",
              "example": "Welding"
            }
          }
        },
        "description": "Compatible materials and applications"
      }
    },
    "validation": {
      "frontmatter": {
        "requiredFields": [
          "name", "description", "website", "author", "keywords", "tags", 
          "properties", "composition", "compatibility", "regulatoryStandards"
        ]
      }
    }
  }
}