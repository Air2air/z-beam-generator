{
  "name": "application",
  "version": "1.1",
  "schemaType": "LaserCleaningApplicationProfile",
  "generatorConfig": {
    "tags": {
      "includeIndustries": true,
      "includeSubstrates": true,
      "includeApplications": true,
      "primaryKeywords": [
        "laser cleaning",
        "{subject}",
        "surface preparation",
        "industrial cleaning",
        "laser technology",
        "manufacturing"
      ]
    },
    "jsonld": {
      "schemaType": "TechArticle",
      "includeIndustries": true,
      "includeSubstrates": true,
      "includeApplications": true,
      "additionalProperties": [
        {
          "name": "applicationCategory",
          "value": "Laser cleaning application"
        },
        {
          "name": "technicalContext",
          "value": "Parameters and outcomes of {subject}"
        }
      ]
    },
    "metadata": {
      "includeDescription": true,
      "includeAuthor": true,
      "includeKeywords": true,
      "includePublicationDate": true,
      "category": "LaserApplications"
    }
  },
  "sections": {
    "overview": {
      "required": true,
      "prompt": "Write a comprehensive overview of the {subject} laser cleaning application. Include its definition, mechanism, primary benefits, and relevance to industries. Keep it concise but informative (200-250 words), emphasizing technical, scientific, and business value."
    },
    "parameters": {
      "required": true,
      "prompt": "Describe the key laser parameters for the {subject} application, including optimal settings for wavelength, power output, pulse duration, repetition rate, scan speed, fluence, spot size, and beam profile. Provide specific ranges with units, explain their impact on cleaning results, and reference standards (e.g., ASTM, ISO) where applicable."
    },
    "outcomes": {
      "required": true,
      "prompt": "Explain the successful outcomes of the {subject} application, including substrate preservation, cleaning efficiency, environmental benefits, and operational advantages. Provide specific examples, quantitative results (e.g., removal rates, energy savings), and industry applications."
    },
    "challenges": {
      "required": true,
      "prompt": "Discuss the main challenges of the {subject} application, such as parameter sensitivity, equipment costs, operator expertise, or substrate limitations. Provide potential solutions, mitigation strategies, and examples of successful implementations."
    },
    "performance": {
      "required": true,
      "prompt": "Detail the performance metrics for the {subject} application, including cycle time, surface roughness, energy consumption, cleaning efficiency, removal rate, and process window. Use specific values with units, cite data sources (e.g., industry reports, ASTM standards), and include comparative benchmarks where possible."
    },
    "comparison": {
      "required": true,
      "prompt": "Compare the {subject} application to traditional cleaning methods (e.g., mechanical, chemical) and other laser-based methods in terms of speed, cost, effectiveness, and environmental impact. Include quantitative data, advantages of laser cleaning, and industry-specific benefits."
    },
    "safety": {
      "required": true,
      "prompt": "Outline the safety considerations and regulatory standards for the {subject} application, including protective equipment, facility requirements, operator training, and compliance with OSHA, ANSI, or ISO standards. Address region-specific regulations if applicable."
    },
    "caseStudies": {
      "required": false,
      "prompt": "Provide real-world case studies or examples of the {subject} application in action. Include specific industries, substrates, outcomes (e.g., efficiency gains, cost savings), and any quantitative results or certifications achieved."
    },
    "innovations": {
      "required": false,
      "prompt": "Discuss recent innovations or technological advancements related to the {subject} application, such as new laser systems, automation, or parameter optimization techniques. Highlight contributions from research or industry and their impact on performance."
    },
    "businessImplications": {
      "required": false,
      "prompt": "Analyze the business implications of the {subject} application, including cost-benefit analysis, scalability, market adoption trends, and competitive advantages. Discuss how it influences decision-making in industries adopting laser cleaning."
    }
  },
  "applicationProfile": {
    "name": {
      "type": "string",
      "required": true,
      "description": "Name of the laser cleaning application",
      "example": "Cleaning for weld surface preparation"
    },
    "description": {
      "type": "string",
      "required": true,
      "description": "Overview of the laser cleaning application",
      "example": "Cleaning for weld surface preparation is a precision laser cleaning technique that removes contaminants from surfaces to ensure high-quality welds."
    },
    "primaryAudience": {
      "type": "string",
      "required": true,
      "description": "Primary target audience for the application",
      "example": "Manufacturing Engineers"
    },
