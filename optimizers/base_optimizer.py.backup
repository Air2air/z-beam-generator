"""
Base Optimizer Class - Common functionality for all optimizers
"""
import re
import json
import logging
from abc import ABC, abstractmethod
from pathlib import Path
from typing import List, Dict, Any, Optional
from config.constants import CONFIG

logger = logging.getLogger(__name__)

class BaseOptimizer(ABC):
    """Base class for all content optimizers"""
    
    def __init__(self, config: Dict[str, Any], api_client):
        """Initialize base optimizer"""
        self.config = config
        self.api_client = api_client
        
        # Load authors from new top-level location
        self.authors = self._load_authors()
        
        logger.info(f"📚 Loading authors from: authors/authors.json")
        logger.info(f"✅ Loaded {len(self.authors)} authors")
        for author in self.authors:
            logger.info(f"👤 Author {author['id']}: {author['name']} ({author['country']})")
    
    @abstractmethod
    def optimize_sections(self, sections: List[Dict], material: str, metadata: Dict) -> List[Dict]:
        """Abstract method for optimizing sections - must be implemented by subclasses"""
        pass
    
    def _load_authors(self) -> List[Dict]:
        """Load authors from configured path - NO FALLBACKS"""
        authors_file = Path(CONFIG.paths["authors_file"])
        
        if not authors_file.exists():
            logger.error(f"❌ Authors file not found: {authors_file}")
            raise FileNotFoundError(f"Required authors file missing: {authors_file}")
        
        try:
            with open(authors_file, 'r', encoding='utf-8') as f:
                authors = json.load(f)
                logger.info(f"✅ Loaded {len(authors)} authors from {authors_file}")
                return authors
        except Exception as e:
            logger.error(f"❌ Error loading authors: {e}")
            raise RuntimeError(f"Failed to load authors: {e}")
    
    def _load_writing_sample(self, author_id: int) -> Optional[str]:
        """Load writing sample for specific author using authors.json configuration"""
        logger.info(f"📖 Loading writing sample for author_id: {author_id}")
        
        # Get author info
        author = self.authors.get(author_id)
        if not author:
            logger.error(f"❌ Author {author_id} not found in authors data")
            return None
        
        logger.info(f"👤 Found author: {author['name']} from {author.get('country', 'Unknown')}")
        
        # Priority order for finding writing samples:
        # 1. Explicit writing_sample_file field in author data
        # 2. Country-based style (style_{country}.md) 
        # 3. Language-based style (style_{language}.md)
        # 4. Default style (style_english.md)
        
        candidates = []
        
        # 1. Check for explicit writing_sample_file in author data
        if 'writing_sample_file' in author:
            sample_path = Path(author['writing_sample_file'])
            candidates.append(sample_path)
            logger.info(f"📋 Found configured writing sample: {sample_path}")
        
        # 2. Country-based style fallback
        if 'country' in author:
            country_style = f"style_{author['country'].lower().replace(' ', '_')}.md"
            candidates.append(Path("optimizers/writing_sample") / country_style)
        
        # 3. Language-based style fallback  
        if 'language' in author:
            language_style = f"style_{author['language'].lower().replace(' ', '_')}.md"
            candidates.append(Path("optimizers/writing_sample") / language_style)
        
        # 4. Default fallback
        candidates.append(Path("optimizers/writing_sample/style_english.md"))
        
        # Find first existing sample
        sample_path = None
        for candidate in candidates:
            if candidate.exists():
                sample_path = candidate
                logger.info(f"📄 Using writing sample: {candidate}")
                break
        
        if not sample_path:
            logger.error(f"❌ No writing sample found for author {author_id}")
            logger.error(f"❌ Tried candidates: {[str(c) for c in candidates]}")
            return None
        
        # Load writing sample
        try:
            with open(sample_path, 'r', encoding='utf-8') as f:
                writing_sample = f.read().strip()
            
            # Clean markdown comments
            clean_sample = self._clean_writing_sample(writing_sample)
            
            logger.info(f"✅ Writing sample loaded from {sample_path.name}: {len(clean_sample)} chars")
            return clean_sample
            
        except Exception as e:
            logger.error(f"❌ Error reading writing sample {sample_path}: {e}")
            return None
    
    def _clean_writing_sample(self, content: str) -> str:
        """Clean writing sample content by removing markdown comments"""
        if not content:
            return ""
        
        lines = content.split('\n')
        clean_lines = []
        in_comment = False
        
        for line in lines:
            stripped = line.strip()
            
            # Skip HTML comments
            if stripped.startswith('<!--'):
                in_comment = True
                continue
            if stripped.endswith('-->'):
                in_comment = False
                continue
            if in_comment:
                continue
                
            # Skip empty lines at the beginning
            if not clean_lines and not stripped:
                continue
                
            clean_lines.append(line)
        
        cleaned = '\n'.join(clean_lines).strip()
        
        # Log cleaning stats
        original_lines = len(lines)
        cleaned_lines = len(clean_lines)
        if original_lines != cleaned_lines:
            logger.info(f"🧹 Cleaned writing sample: {original_lines} → {cleaned_lines} lines")
        
        return cleaned
    
    def _validate_writing_sample(self):
        """Validate that writing samples exist for all authors"""
        logger.info("🔍 Validating writing samples for all authors...")
        
        missing_samples = []
        
        for author_id, author in self.authors.items():
            author_name = author.get('name', f'Author {author_id}')
            
            # Check if writing_sample_file exists
            if 'writing_sample_file' in author:
                sample_path = Path(author['writing_sample_file'])
                if sample_path.exists():
                    logger.info(f"✅ {author_name}: {sample_path.name}")
                else:
                    logger.warning(f"⚠️ {author_name}: Missing {sample_path}")
                    missing_samples.append((author_id, sample_path))
            else:
                logger.warning(f"⚠️ {author_name}: No writing_sample_file specified")
        
        if missing_samples:
            logger.warning(f"⚠️ Found {len(missing_samples)} missing writing samples")
            for author_id, path in missing_samples:
                logger.warning(f"  📄 Author {author_id}: {path}")
        else:
            logger.info("✅ All writing samples validated successfully")
    
    def _convert_sections_to_internal(self, sections: List[Dict]) -> List[Dict]:
        """Convert sections to internal format"""
        text_sections = []
        for section in sections:
            text_sections.append({
                'name': section.get('title', '').lower().replace(' ', '_').replace('_with_', '_'),
                'title': section.get('title', 'Untitled'),
                'content': section.get('content', '')
            })
        return text_sections
    
    def _convert_sections_to_output(self, sections: List[Dict]) -> List[Dict]:
        """Convert sections to output format"""
        result = []
        for section in sections:
            result.append({
                'title': section.get('title', 'Optimized Content'),
                'content': section.get('content', '')
            })
        return result
    
    def _combine_sections(self, text_sections: List[Dict]) -> str:
        """Combine sections into a single article"""
        combined = []
        for section in text_sections:
            combined.append(f"## {section['title']}")
            combined.append(section['content'])
            combined.append("")  # Empty line between sections
        return "\n".join(combined)
    
    def _split_optimized_content(self, optimized_content: str, original_sections: List[Dict]) -> List[Dict]:
        """Split optimized full content back into individual sections"""
        logger.info("🔧 Splitting optimized content back into sections")
        
        # Split by markdown headers (## Section Title)
        sections = re.split(r'\n## ', optimized_content)
        
        # Remove empty first element if present
        if sections and not sections[0].strip():
            sections = sections[1:]
        
        # Add back the ## markers (except for first section if it already has ##)
        for i in range(len(sections)):
            if not sections[i].startswith('##') and i > 0:
                sections[i] = "## " + sections[i]
        
        logger.info(f"📊 Split into {len(sections)} sections from optimized content")
        
        # Match sections back to original structure
        optimized_sections = []
        
        for i, original_section in enumerate(original_sections):
            if i < len(sections):
                section_content = sections[i].strip()
                
                # Extract title and content
                lines = section_content.split('\n', 1)
                if len(lines) >= 2 and lines[0].startswith('##'):
                    # Remove ## from title
                    title = lines[0].replace('##', '').strip()
                    content = lines[1].strip()
                elif len(lines) >= 2:
                    title = lines[0].strip()
                    content = lines[1].strip()
                else:
                    title = original_section['title']
                    content = section_content
                
                optimized_sections.append({
                    'name': original_section.get('name', title.lower().replace(' ', '_')),
                    'title': title,
                    'content': content
                })
                
                logger.info(f"✅ Section '{title}' extracted: {len(content)} chars")
            else:
                # Fallback if section missing
                logger.warning(f"⚠️ Section '{original_section['title']}' not found in optimized content, using original")
                optimized_sections.append(original_section)
        
        # Validate section count
        if len(optimized_sections) != len(original_sections):
            logger.warning(f"⚠️ Section count mismatch: expected {len(original_sections)}, got {len(optimized_sections)}")
        
        return optimized_sections
    
    def _count_words(self, text: str) -> int:
        """Simple word count"""
        return len(text.split())
    
    def _log_section_details(self, sections: List[Dict], phase: str = "Input"):
        """Log details about sections"""
        logger.info(f"📋 {phase} SECTIONS DETAILS:")
        for i, section in enumerate(sections, 1):
            chars = len(section.get('content', ''))
            words = self._count_words(section.get('content', ''))
            title = section.get('title', section.get('name', 'unknown'))
            logger.info(f"  📄 Section {i}: '{title}' - {chars} chars, {words} words")
    
    def _validate_sections(self, sections: List[Dict]) -> bool:
        """Validate that sections have required fields"""
        for i, section in enumerate(sections):
            if not isinstance(section, dict):
                logger.error(f"❌ Section {i+1} is not a dictionary")
                return False
            
            if not section.get('title'):
                logger.warning(f"⚠️ Section {i+1} missing title")
            
            if not section.get('content'):
                logger.warning(f"⚠️ Section {i+1} missing content")
        
        return True
    
    def _ensure_word_limits(self, sections: List[Dict]) -> List[Dict]:
        """Ensure sections meet word limit requirements with smart truncation"""
        max_words = self.config.get('max_section_words', 75)
        target_words = self.config.get('target_section_words', 75)
        
        logger.info(f"📏 Enforcing word limits: max={max_words}, target={target_words}")
        logger.info(f"🔧 Optimization method: {self.config.get('optimization_method', 'unknown')}")
        
        processing_stats = {
            "sections_processed": len(sections),
            "total_words_before": 0,
            "total_words_after": 0,
            "truncations_applied": 0
        }
        
        for section in sections:
            content = section.get('content', '')
            words_before = self._count_words(content)
            processing_stats["total_words_before"] += words_before
            
            if words_before > max_words:
                # Smart truncation - try to complete sentences
                truncated_content = self._smart_truncate(content, max_words)
                section['content'] = truncated_content
                processing_stats["truncations_applied"] += 1
                
                final_words = self._count_words(truncated_content)
                logger.info(f"📏 Smart truncated '{section['title']}' from {words_before} to {final_words} words")
            else:
                final_words = words_before
            
            processing_stats["total_words_after"] += final_words
            logger.info(f"📄 Final section '{section['title']}': {final_words} words")
        
        # Log processing summary
        logger.info(f"📊 WORD LIMIT PROCESSING SUMMARY:")
        logger.info(f"  🔢 Sections processed: {processing_stats['sections_processed']}")
        logger.info(f"  📝 Total words before: {processing_stats['total_words_before']}")
        logger.info(f"  📝 Total words after: {processing_stats['total_words_after']}")
        logger.info(f"  ✂️ Truncations applied: {processing_stats['truncations_applied']}")
        logger.info(f"  📊 Word reduction: {processing_stats['total_words_before'] - processing_stats['total_words_after']} words")
        
        return sections

    def _smart_truncate(self, content: str, max_words: int) -> str:
        """Truncate content while trying to preserve sentence completion"""
        words = content.split()
        
        if len(words) <= max_words:
            return content
        
        # Take max_words and try to find a good stopping point
        truncated_words = words[:max_words]
        truncated_text = ' '.join(truncated_words)
        
        # Look for sentence endings within the last 10 words
        for i in range(min(10, len(truncated_words))):
            test_words = truncated_words[:-(i+1)]
            test_text = ' '.join(test_words)
            
            # Check if it ends with sentence punctuation
            if test_text.endswith(('.', '!', '?')):
                logger.info(f"🎯 Found sentence boundary at word {len(test_words)}")
                return test_text
        
        # If no sentence boundary found, add ellipsis to indicate continuation
        if not truncated_text.endswith(('.', '!', '?')):
            # Remove any trailing punctuation and add ellipsis
            truncated_text = truncated_text.rstrip('.,!?;:') + '...'
        
        return truncated_text