{
  "formatting": {
    "style": "hashtag",
    "separator": ", ",
    "case_format": "title",
    "remove_spaces": false,
    "prefix": "#",
    "suffix": "",
    "max_tags_per_line": 6,
    "sort_tags": true,
    "group_by_category": true
  },
  "generation": {
    "max_tags": 12,
    "min_tags": 8,
    "include_material": true,
    "include_technical": true,
    "include_industry": true,
    "include_safety": true,
    "avoid_generic": true
  }
}